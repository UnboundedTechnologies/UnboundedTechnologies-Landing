# Runtime env schema is enforced by Zod in src/lib/env.ts. All values here are
# either optional (the related feature soft-fails) or have a sensible default
# baked into the schema. Copy this file to .env.local for local development.

# === PUBLIC (browser-safe) ===
NEXT_PUBLIC_SITE_URL=https://unboundedtechnologies.com
PLAUSIBLE_DOMAIN=unboundedtechnologies.com

# === RESEND (transactional email) ===
# Both confirmations + the owner-facing lead notification go through Resend.
# Defaults are baked into env.ts so missing values do not crash the schema;
# but with no API key the Resend client builds to null and the route handler
# silently skips email send.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@send.unboundedtechnologies.com
RESEND_TO_EMAIL=contact@unboundedtechnologies.com

# === NOTION CRM ===
# Both must be present together for the leads database write to happen.
NOTION_API_KEY=
NOTION_LEADS_DB_ID=

# === CALENDLY ===
# Booking-card target. If absent, the funnel renders a graceful placeholder
# instead of the outbound CTA card.
CALENDLY_URL=

# === GITHUB ===
# Optional. Raises the public GitHub API rate limit from 60/hr to 5000/hr,
# which the GitHub-strip widget uses for live activity reads.
GITHUB_TOKEN=

# === UPSTASH REDIS (form rate limiting) ===
# 3 submissions / hour / IP sliding window. If absent, the limiter falls back
# to a noop that always returns success.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === PAGESPEED INSIGHTS (CI-only) ===
# Used by .github/workflows/lighthouse-weekly.yml to call PSI for /en/services.
# Not read at runtime, so leaving this empty locally is fine.
PSI_API_KEY=
